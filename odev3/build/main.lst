  73:Core/Src/main.c **** void HAL_TIM_PeriodElapsedCallback(TIM_HandleTypeDef *htim)
  74:Core/Src/main.c **** {
  75:Core/Src/main.c ****     if (htim->Instance != TIM2) return;
  76:Core/Src/main.c **** 
  77:Core/Src/main.c ****     if (beklemede)
  78:Core/Src/main.c ****     {
  79:Core/Src/main.c ****         bekleme_sayaci++;
  80:Core/Src/main.c ****         if (bekleme_sayaci >= 5)
  81:Core/Src/main.c ****         {
  82:Core/Src/main.c ****             beklemede    = 0;
  83:Core/Src/main.c ****             bekleme_sayaci = 0;
  84:Core/Src/main.c ****             blink_done  = 0;
  85:Core/Src/main.c ****             ledin_durumu   = 0;
  86:Core/Src/main.c ****         }
  87:Core/Src/main.c ****         return;
  88:Core/Src/main.c ****     }
  89:Core/Src/main.c **** 
  90:Core/Src/main.c ****     if (ledin_durumu == 0)
  91:Core/Src/main.c ****     {
  92:Core/Src/main.c ****         HAL_GPIO_WritePin(GPIOC, GPIO_PIN_13, GPIO_PIN_RESET);
  93:Core/Src/main.c ****         ledin_durumu = 1;
  94:Core/Src/main.c ****     }
  95:Core/Src/main.c ****     else
  96:Core/Src/main.c ****     {
  97:Core/Src/main.c ****         HAL_GPIO_WritePin(GPIOC, GPIO_PIN_13, GPIO_PIN_SET);
  98:Core/Src/main.c ****         ledin_durumu = 0;
  99:Core/Src/main.c ****         blink_done++;
 100:Core/Src/main.c **** 
 101:Core/Src/main.c ****         if (blink_done >= blink_sayisi)
 102:Core/Src/main.c ****         {
 103:Core/Src/main.c ****             beklemede    = 1;
 104:Core/Src/main.c ****             bekleme_sayaci = 0;
 105:Core/Src/main.c ****         }
 106:Core/Src/main.c ****     }
 107:Core/Src/main.c **** }
